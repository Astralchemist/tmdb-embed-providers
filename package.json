{
  "name": "tmdb-embed-providers",
  "version": "0.1.1",
  "description": "Curated, typed list of TMDB-id-keyed video embed providers for movies and TV. Core + Asian-friendly extras tiers, plus a built-in probeProvider() health check. Zero runtime dependencies.",
  "keywords": [
    "tmdb",
    "embed",
    "movie",
    "tv",
    "subtitles",
    "asian-drama",
    "kdrama",
    "anime",
    "providers"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Astralchemist/tmdb-embed-providers.git"
  }
}
